# ════════════════════════════════════════════════════════════════
# Oxidian — Variables de entorno para PRODUCCIÓN
# Copia este archivo a .env.cosmos.local y rellena los valores.
# NUNCA commitees el archivo con contraseñas reales.
# ════════════════════════════════════════════════════════════════

# ── Seguridad ─────────────────────────────────────────────────
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIA_ESTO_POR_UNA_CLAVE_ALEATORIA_DE_64_CHARS

# Contraseña para el admin y superadmin que se crea en el primer arranque
SEED_PASSWORD=CAMBIA_ESTO_POR_CONTRASENA_FUERTE
ADMIN_EMAIL=admin@tudominio.com
SUPERADMIN_EMAIL=superadmin@tudominio.com
# 1 obliga a configurar MFA para administradores en producción.
OXIDIAN_MFA_ENFORCED=1

# ── Aplicación ────────────────────────────────────────────────
# URL pública completa (con https si tienes TLS)
OXIDIAN_PUBLIC_URL=https://tudominio.com
TIENDA_URL=https://tudominio.com
# Puerto local del gateway si arrancas con Docker Compose directo.
# En Cosmos, el dominio debe apuntar al servicio gateway/puerto 80.
PUBLIC_PORT=8088
# Directorio del host que contiene config.yml y credenciales de cloudflared.
CLOUDFLARED_CONFIG_DIR=/home/tu_usuario/.cloudflared

# ── Negocio ───────────────────────────────────────────────────
NOMBRE_NEGOCIO="Mi tienda"
TELEFONO_NEGOCIO=+34600000000
DIRECCION_NEGOCIO="Calle y número"
CIUDAD_NEGOCIO="Tu ciudad"
PROVINCIA_NEGOCIO="Tu provincia"
PAIS_NEGOCIO="Tu país"
PAIS_CODIGO_ISO=es
WHATSAPP_COUNTRY_CODE=34

# ── Base de datos Oxidian ─────────────────────────────────────
OXIDIAN_DB_USER=oxidian
OXIDIAN_DB_PASSWORD=CAMBIA_ESTO_POR_CONTRASENA_BD_FUERTE
OXIDIAN_DB_NAME=oxidian

# ── Evolution API (WhatsApp) ──────────────────────────────────
# Cambia la clave API por una larga y aleatoria
EVOLUTION_API_KEY=CAMBIA_ESTO_API_KEY_EVOLUTION
EVOLUTION_INSTANCE=parcerito
EVOLUTION_IMAGE=evoapicloud/evolution-api:v2.3.7
EVOLUTION_DB_USER=evolution
EVOLUTION_DB_PASSWORD=CAMBIA_ESTO_CONTRASENA_EVOLUTION_BD
EVOLUTION_DB_NAME=evolution
CONFIG_SESSION_PHONE_VERSION=2.3000.1030415680

# ── Chatbot ───────────────────────────────────────────────────
# Genera con: python -c "import secrets; print(secrets.token_hex(20))"
BOT_API_KEY=CAMBIA_ESTO_BOT_KEY
BOT_PANEL_KEY=CAMBIA_ESTO_PANEL_KEY
BOT_PUBLIC_URL=
# Secreto que Evolution enviará al webhook del bot.
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=CAMBIA_ESTO_WEBHOOK_SECRET

# Tu número de WhatsApp sin + (ej: 34622663874)
OWNER_NUMBER=34XXXXXXXXX
# Números de superadmin separados por coma
SUPERADMINS=34XXXXXXXXX

# ── Producción ────────────────────────────────────────────────
# CRÍTICO: 0 en desarrollo, 1 en producción con HTTPS
SIMULATE_EVO_SEND=0
SESSION_COOKIE_SECURE=1
WEB_CONCURRENCY=4

# CRÍTICO: 0 en producción para no borrar el catálogo real
SEED_SHOWCASE_CATALOG=0
# 1 = primer arranque limpio: solo super admin, armado y repartidor
OXIDIAN_MINIMAL_USERS=1

# Zona horaria
TZ=Europe/Madrid
