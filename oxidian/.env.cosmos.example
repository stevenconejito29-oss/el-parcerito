# Copia este archivo a .env.cosmos.local para pruebas locales.
# En Cosmos cambia SECRET_KEY, passwords y claves API por valores fuertes.

SECRET_KEY=change-me-local-cosmos-secret
SEED_PASSWORD=oxidian-local-2026
ADMIN_EMAIL=admin@oxidian.local
SUPERADMIN_EMAIL=superadmin@oxidian.local

PUBLIC_PORT=5070
OXIDIAN_PUBLIC_URL=http://localhost:5070
TIENDA_URL=http://localhost:5070
NOMBRE_NEGOCIO="Mi tienda"
TELEFONO_NEGOCIO=
DIRECCION_NEGOCIO=
CIUDAD_NEGOCIO=
PROVINCIA_NEGOCIO=
PAIS_NEGOCIO=
PAIS_CODIGO_ISO=
WHATSAPP_COUNTRY_CODE=
RADIO_ENTREGA_KM=5
VALIDAR_RADIO_ENTREGA=1
BLOQUEAR_DIRECCION_NO_VERIFICADA=1

OXIDIAN_DB_USER=oxidian
OXIDIAN_DB_PASSWORD=oxidian_local_password
OXIDIAN_DB_NAME=oxidian

EVOLUTION_API_KEY=localevoapikey
EVOLUTION_INSTANCE=oxidian
EVOLUTION_IMAGE=evoapicloud/evolution-api:v2.3.7
EVOLUTION_DB_USER=evolution
EVOLUTION_DB_PASSWORD=evolution_local_password
EVOLUTION_DB_NAME=evolution
CONFIG_SESSION_PHONE_VERSION=2.3000.1030415680

BOT_API_KEY=local-evolution-bot-key
BOT_PANEL_KEY=local-evolution-bot-key
BOT_ALLOW_ORDER_CREATE=0
BOT_EMAIL_DOMAIN=wa.internal
BOT_PUBLIC_URL=
OWNER_NUMBER=34000000000
SUPERADMINS=34000000000
DB_DIR=/app/bot-data
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=change-me-local-webhook-secret-32-chars-min
OUTBOX_LIMIT=50
OUTBOX_INTERVAL_SECONDS=60

# 1 = pruebas sin WhatsApp real conectado. En producción debe ser 0.
SIMULATE_EVO_SEND=1

SEED_SHOWCASE_CATALOG=0
OXIDIAN_MINIMAL_USERS=1
WEB_CONCURRENCY=2
TZ=Europe/Madrid

# Local HTTP: 0. En Cosmos con HTTPS: 1.
SESSION_COOKIE_SECURE=0
